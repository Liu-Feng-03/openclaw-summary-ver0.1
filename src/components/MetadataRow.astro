---
const { audience, difficulty, readingTime, tags = [] } = Astro.props;
const items = [
  audience && `适合：${audience}`,
  difficulty && `难度：${difficulty}`,
  readingTime && `阅读：${readingTime}`,
  ...tags.slice(0, 3).map((tag) => `#${tag}`)
].filter(Boolean);
---
<div class="meta-row">
  {items.map((item) => <span class="meta-pill">{item}</span>)}
</div>
